<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UABEA.Android.AssetInfoView">
    <Border Background="#80000000"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border Background="#222" CornerRadius="8" Padding="16"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="520" MaxWidth="720" MinHeight="520">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Title -->
                <TextBlock Grid.Row="0" Text="文件信息" FontSize="18" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,12"/>

                <!-- TabControl -->
                <TabControl Grid.Row="1" Name="tabControl" Margin="0,0,0,8">

                    <!-- Header Tab -->
                    <TabItem Header="Header">
                        <ScrollViewer Padding="0">
                            <Grid Margin="8" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                  ColumnDefinitions="160,*">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="MetadataSize" Foreground="#ccc" Margin="0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Name="lblMetadataSize" Foreground="White" TextWrapping="Wrap" Margin="0,4"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="FileSize" Foreground="#ccc" Margin="0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Name="lblFileSize" Foreground="White" TextWrapping="Wrap" Margin="0,4"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Format" Foreground="#ccc" Margin="0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Name="lblFormat" Foreground="White" TextWrapping="Wrap" Margin="0,4"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="DataOffset" Foreground="#ccc" Margin="0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Name="lblDataOffset" Foreground="White" TextWrapping="Wrap" Margin="0,4"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Endianness" Foreground="#ccc" Margin="0,4"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Name="lblEndianness" Foreground="White" TextWrapping="Wrap" Margin="0,4"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="EngineVersion" Foreground="#ccc" Margin="0,4"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Name="lblEngineVersion" Foreground="White" TextWrapping="Wrap" Margin="0,4"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="TargetPlatform" Foreground="#ccc" Margin="0,4"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Name="lblTargetPlatform" Foreground="White" TextWrapping="Wrap" Margin="0,4"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="TypeTreeEnabled" Foreground="#ccc" Margin="0,4"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Name="lblTypeTreeEnabled" Foreground="White" TextWrapping="Wrap" Margin="0,4"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="文件名" Foreground="#ccc" Margin="0,4"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Name="lblFileName" Foreground="White" TextWrapping="Wrap" Margin="0,4"/>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- TypeTree Tab -->
                    <TabItem Header="TypeTree">
                        <Grid RowDefinitions="Auto,*">
                            <TextBlock Grid.Row="0" Name="lblTypeTreeHint" Foreground="#aaa" FontSize="11"
                                       Margin="4,4,4,2" TextWrapping="Wrap"/>
                            <ListBox Grid.Row="1" Name="lstTypeTree" Background="#1a1a1a">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2,4" Spacing="2">
                                            <TextBlock Text="{Binding Display}" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>

                    <!-- Dependencies Tab -->
                    <TabItem Header="Dependencies">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Grid.Row="0" ColumnDefinitions="2*,3*" Margin="4,4,4,2">
                                <TextBlock Grid.Column="0" Text="c_FilePath" Foreground="#aaa" FontSize="11"/>
                                <TextBlock Grid.Column="1" Text="c_AssetPath" Foreground="#aaa" FontSize="11" Margin="8,0,0,0"/>
                            </Grid>
                            <ListBox Grid.Row="1" Name="lstDeps" Background="#1a1a1a">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="2*,3*">
                                            <TextBlock Grid.Column="0" Text="{Binding FilePath}" Foreground="White"
                                                       FontSize="12" TextWrapping="Wrap" Margin="0,0,8,4"/>
                                            <TextBlock Grid.Column="1" Text="{Binding AssetPath}" Foreground="#a0d0ff"
                                                       FontSize="12" TextWrapping="Wrap" Margin="8,0,0,4"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                </TabControl>

                <!-- Close button -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Name="btnClose" Content="关闭" Height="40" MinWidth="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
