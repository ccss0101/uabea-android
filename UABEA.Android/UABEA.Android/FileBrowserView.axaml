<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UABEA.Android.FileBrowserView">
    <!--
      内置文件选择系统：避免调用系统 StorageProvider 导致应用掉后台被回收。
      直接通过 System.IO 遍历存储目录，支持目录导航、过滤、选择。
    -->
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="4">
        <!-- 标题栏 -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Name="titleText" Text="选择文件" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Name="btnCancel" Content="取消" Height="36" MinWidth="70"/>
        </Grid>

        <!-- 路径栏 -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,4">
            <Button Grid.Column="0" Name="btnUp" Content="上级" Height="36" MinWidth="60" FontSize="12"/>
            <TextBox Grid.Column="1" Name="pathBox" IsReadOnly="True" FontSize="11" Margin="4,0" Watermark="当前路径"/>
            <Button Grid.Column="2" Name="btnHome" Content="主页" Height="36" MinWidth="60" FontSize="12" Margin="2,0,0,0"/>
            <Button Grid.Column="3" Name="btnRefresh" Content="刷新" Height="36" MinWidth="60" FontSize="12" Margin="2,0,0,0"/>
        </Grid>

        <!-- 文件列表 -->
        <ListBox Grid.Row="2" Name="fileList" FontSize="13">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="2">
                        <TextBlock Text="{Binding Icon}" FontSize="16" Width="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 底部操作栏 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" Margin="0,4,0,0">
            <Button Name="btnConfirm" Content="选择此文件" Height="40" MinWidth="120" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</UserControl>
