<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:android="clr-namespace:UABEA.Android"
             x:Class="UABEA.Android.FilterTypeView">
    <Border Background="#80000000"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border Background="#222" CornerRadius="8" Padding="16"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="320" MaxWidth="500" MaxHeight="600">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
                <TextBlock Grid.Row="0" Text="按类型过滤" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <Button Name="btnSelectAll" Content="全选" Height="34" MinWidth="70" FontSize="12"/>
                    <Button Name="btnDeselectAll" Content="全不选" Height="34" MinWidth="70" FontSize="12"/>
                    <TextBlock Name="summary" VerticalAlignment="Center" Foreground="#aaa" FontSize="12"/>
                </StackPanel>
                <ScrollViewer Grid.Row="2" MaxHeight="420" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl Name="typeList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type android:FilterTypeRow}">
                                <CheckBox Content="{Binding TypeName}" IsChecked="{Binding Enabled}" Margin="0,4" Foreground="White"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Name="btnConfirm" Content="应用" Height="40" MinWidth="90"/>
                    <Button Name="btnCancel" Content="取消" Height="40" MinWidth="70"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
