<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UABEA.Android.GoToAssetView">
    <Border Background="#80000000"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border Background="#222" CornerRadius="8" Padding="16"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="320" MaxWidth="460">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Text="跳转到资产" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <TextBlock Text="PathID:" FontSize="14" VerticalAlignment="Center" Foreground="White"/>
                    <TextBox Name="boxPathId" Watermark="输入 PathID" FontSize="14" MinWidth="200"/>
                </StackPanel>
                <TextBlock Grid.Row="2" Name="errorText" FontSize="11" Foreground="#ff6666" Margin="0,0,0,8" IsVisible="False"/>
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Name="btnConfirm" Content="跳转" Height="40" MinWidth="90"/>
                    <Button Name="btnCancel" Content="取消" Height="40" MinWidth="70"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
