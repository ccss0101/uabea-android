<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uabea="clr-namespace:UABEAvalonia;assembly=UABEA.Core"
             xmlns:android="clr-namespace:UABEA.Android"
             x:Class="UABEA.Android.MainView">
    <!-- 设置弹出层用到的配置项 DataTemplate（按运行时类型自动选择） -->
    <UserControl.DataTemplates>
        <DataTemplate DataType="{x:Type uabea:ConfigurationBooleanItem}">
            <StackPanel Margin="0,8" Spacing="2">
                <CheckBox IsChecked="{Binding Value}" Content="{Binding Title}"/>
                <TextBlock Text="{Binding Description}" Opacity="0.6" TextWrapping="Wrap" Margin="24,0,0,0" FontSize="11"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type uabea:ConfigurationIntegerItem}">
            <StackPanel Margin="0,8" Spacing="2">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                <NumericUpDown Value="{Binding Value}" Minimum="{Binding RangeMin}" Maximum="{Binding RangeMax}" Width="180" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding Description}" Opacity="0.6" TextWrapping="Wrap" FontSize="11"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type uabea:ConfigurationEnumItem}">
            <StackPanel Margin="0,8" Spacing="2">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding EnumValues}" SelectedItem="{Binding Value}" Width="200" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding Description}" Opacity="0.6" TextWrapping="Wrap" FontSize="11"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>
    <Panel>
        <Grid Margin="8" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">
            <!-- 标题 -->
            <TextBlock Grid.Row="0" Text="UABEA Android" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,4"/>

            <!-- 状态 -->
            <TextBlock Grid.Row="1" Name="statusText" Text="初始化中..." FontSize="13" Margin="0,0,0,4" TextWrapping="Wrap"/>

            <!-- 文件操作按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4" HorizontalAlignment="Center">
                <Button Name="btnOpen" Content="打开" Height="46" MinWidth="70" FontSize="13"/>
                <Button Name="btnSave" Content="保存" Height="46" MinWidth="70" FontSize="13" IsEnabled="False"/>
                <Button Name="btnCompress" Content="压缩" Height="46" MinWidth="70" FontSize="13" IsEnabled="False"/>
                <Button Name="btnClose" Content="关闭" Height="46" MinWidth="70" FontSize="13" IsEnabled="False"/>
                <Button Name="btnSettings" Content="设置" Height="46" MinWidth="70" FontSize="13"/>
            </StackPanel>

            <!-- 资产列表标题 + 导出全部 -->
            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,0,0,2">
                <TextBlock Grid.Column="0" Text="资产列表：" FontSize="13"/>
                <Button Grid.Column="1" Name="btnExportAll" Content="导出全部" Height="36" MinWidth="80" FontSize="12" IsEnabled="False"/>
            </Grid>

            <!-- 资产列表 -->
            <ListBox Grid.Row="4" Name="assetList" FontSize="13" MinHeight="120">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SizeText}" FontSize="10" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 单项操作按钮 -->
            <WrapPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,4">
                <Button Name="btnPreview" Content="预览" Height="46" MinWidth="64" FontSize="12" IsEnabled="False" Margin="2"/>
                <Button Name="btnInfo" Content="Info" Height="46" MinWidth="64" FontSize="12" IsEnabled="False" Margin="2"/>
                <Button Name="btnExport" Content="导出" Height="46" MinWidth="64" FontSize="12" IsEnabled="False" Margin="2"/>
                <Button Name="btnImport" Content="导入" Height="46" MinWidth="64" FontSize="12" IsEnabled="False" Margin="2"/>
                <Button Name="btnDump" Content="Dump" Height="46" MinWidth="64" FontSize="12" IsEnabled="False" Margin="2"/>
                <Button Name="btnRename" Content="重命名" Height="46" MinWidth="64" FontSize="12" IsEnabled="False" Margin="2"/>
                <Button Name="btnRemove" Content="删除" Height="46" MinWidth="64" FontSize="12" IsEnabled="False" Margin="2"/>
            </WrapPanel>

            <!-- 日志 -->
            <Border Grid.Row="6" Background="#1a1a1a" CornerRadius="4" Padding="6" MinHeight="60" MaxHeight="140">
                <TextBox Name="logBox" IsReadOnly="True" FontFamily="monospace" FontSize="10"
                         Background="Transparent" Foreground="#00ff00" TextWrapping="Wrap"
                         AcceptsReturn="True" ScrollViewer.VerticalScrollBarVisibility="Auto"
                         BorderThickness="0" Watermark="启动日志"/>
            </Border>
        </Grid>

        <!-- 重命名弹出层 -->
        <Border Name="renameOverlay" IsVisible="False"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#222" CornerRadius="8" Padding="16"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="280">
                <StackPanel Spacing="10">
                    <TextBlock Text="输入新名称" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBox Name="renameBox" FontSize="14" Watermark="新文件名"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Name="renameOk" Content="确定" Height="40" MinWidth="80"/>
                        <Button Name="renameCancel" Content="取消" Height="40" MinWidth="80"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- 导入弹出层（选择是否序列化） -->
        <Border Name="importOverlay" IsVisible="False"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#222" CornerRadius="8" Padding="16"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="300">
                <StackPanel Spacing="10">
                    <TextBlock Text="导入类型" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Name="importFileName" FontSize="12" Foreground="#aaa" TextWrapping="Wrap"/>
                    <TextBlock Text="该文件是否为序列化 assets 文件？" FontSize="13" Foreground="White" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Name="importYes" Content="是 (assets)" Height="40" MinWidth="90"/>
                        <Button Name="importNo" Content="否 (资源)" Height="40" MinWidth="90"/>
                        <Button Name="importCancel" Content="取消" Height="40" MinWidth="80"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- 压缩弹出层（选择压缩方式） -->
        <Border Name="compressOverlay" IsVisible="False"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#222" CornerRadius="8" Padding="16"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="300">
                <StackPanel Spacing="10">
                    <TextBlock Text="压缩方式" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="LZ4：速度快，体积大&#x0a;LZMA：速度慢，体积小" FontSize="13" Foreground="White" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Name="compLz4" Content="LZ4" Height="40" MinWidth="80"/>
                        <Button Name="compLzma" Content="LZMA" Height="40" MinWidth="80"/>
                        <Button Name="compCancel" Content="取消" Height="40" MinWidth="80"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- 进度遮罩 -->
        <Border Name="progressOverlay" IsVisible="False"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#222" CornerRadius="8" Padding="20"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="240">
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Name="progressText" Text="处理中..." FontSize="16" Foreground="White" HorizontalAlignment="Center"/>
                    <ProgressBar Name="progressBar" IsIndeterminate="True" MinWidth="200"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- 预览弹出层 -->
        <Border Name="previewOverlay" IsVisible="False"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#222" CornerRadius="8" Padding="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="450" MaxHeight="650">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <TextBlock Grid.Row="0" Name="previewTitle" Text="预览" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1" Name="previewInfo" FontSize="11" Foreground="#aaa" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    <ScrollViewer Grid.Row="2" MaxHeight="420" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Image Name="previewImage" IsVisible="False" Stretch="Uniform" MaxWidth="400" MaxHeight="400"/>
                            <TextBox Name="previewTextBox" IsVisible="False"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     FontFamily="monospace" FontSize="11"
                                     MinWidth="300" MinHeight="200"
                                     MaxWidth="400" MaxHeight="400"
                                     Background="#111" Foreground="#ddd"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </ScrollViewer>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Name="btnReplaceTexture" Content="替换贴图" Height="40" MinWidth="90" IsVisible="False"/>
                        <Button Name="btnSaveText" Content="保存文本" Height="40" MinWidth="90" IsVisible="False"/>
                        <Button Name="btnClosePreview" Content="关闭" Height="40" MinWidth="80"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- 设置弹出层：复用 ConfigurationManager + ConfigurationItem 反射系统。
             Android 单视图模式下用 overlay 代替 Window.ShowDialog。 -->
        <Border Name="settingsOverlay" IsVisible="False"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource SystemRegionBrush}" CornerRadius="8" Padding="16"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="320" MaxWidth="450" MaxHeight="650">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" MaxHeight="500">
                        <ItemsControl Name="settingsItems"/>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Name="btnSettingsClose" Content="关闭" Height="40" MinWidth="90"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- 内置文件选择器弹出层：避免系统文件选择器导致应用掉后台被回收。
             直接通过 System.IO 遍历存储目录，全程在应用进程内完成。 -->
        <Border Name="fileBrowserOverlay" IsVisible="False"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource SystemRegionBrush}" CornerRadius="8" Padding="12"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Margin="8">
                <android:FileBrowserView Name="fileBrowser"/>
            </Border>
        </Border>
    </Panel>
</UserControl>
