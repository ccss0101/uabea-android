<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:android="clr-namespace:UABEA.Android"
             x:Class="UABEA.Android.MainView">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 顶栏 -->
            <RowDefinition Height="Auto"/>   <!-- 搜索栏 -->
            <RowDefinition Height="*"/>      <!-- 列表 / 编辑区 -->
            <RowDefinition Height="Auto"/>   <!-- 状态栏 -->
            <RowDefinition Height="Auto"/>   <!-- 日志 -->
        </Grid.RowDefinitions>

        <!-- ===== 顶栏 ===== -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="10,6">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="UABEA 文字翻译" FontSize="16" FontWeight="Bold"
                           Foreground="#4EC9B0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Name="topStatus" Text="就绪 - 点击打开选择文件目录"
                           FontSize="11" Foreground="#969696" VerticalAlignment="Center" Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="2" Name="btnOpen"   Content="打开"  Height="36" MinWidth="72" Margin="2" FontSize="13"/>
                <Button Grid.Column="3" Name="btnSaveAll" Content="保存全部" Height="36" MinWidth="82" Margin="2" FontSize="13" IsEnabled="False"/>
                <Button Grid.Column="4" Name="btnExportTxt" Content="导出TXT" Height="36" MinWidth="88" Margin="2" FontSize="13" IsEnabled="False"/>
                <Button Grid.Column="5" Name="btnImportTxt" Content="导入TXT" Height="36" MinWidth="88" Margin="2" FontSize="13" IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- ===== 搜索栏 ===== -->
        <Border Grid.Row="1" Background="#252526" Padding="10,4">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBox Grid.Column="0" Name="searchBox" Watermark="搜索文字..." Height="34" FontSize="13"/>
                <Button Grid.Column="1" Name="btnClearSearch" Content="✕" Height="34" MinWidth="36" Margin="4,0,0,0" FontSize="14"/>
                <ToggleSwitch Grid.Column="2" Name="toggleShowModified" Content="仅显示已改" Margin="8,0,0,0" IsVisible="False"/>
                <TextBlock Grid.Column="3" Name="resultCount" Text="" FontSize="11" Foreground="#969696" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- ===== 列表 / 编辑区(双面板) ===== -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" Margin="0" Background="#1E1E1E">
            <!-- 左:条目列表 -->
            <Border Grid.Column="0" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Background="#2D2D30" Margin="8,4">
                        <TextBlock Grid.Column="0" Text="文字条目" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12"/>
                        <TextBlock Grid.Column="1" Name="listStats" Text="" FontSize="11" Foreground="#969696"/>
                    </Grid>
                    <ListBox Grid.Row="1" Name="entryList" FontSize="12" Background="#1E1E1E" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,4" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding FilePath}" FontSize="10" Foreground="#569CD6" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding FieldPath}" FontSize="10" Foreground="#9CDCFE" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Original}" FontSize="12" Foreground="#E6E6E6" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding Translated}" FontSize="12" Foreground="#4EC9B0" FontStyle="Italic" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右:编辑区 -->
            <Border Grid.Column="1" BorderBrush="#3F3F46" BorderThickness="0,0,0,0">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Background="#2D2D30" Margin="8,4">
                        <TextBlock Grid.Column="0" Text="编辑" FontWeight="SemiBold" Foreground="#CCCCCC" FontSize="12"/>
                        <TextBlock Grid.Column="1" Name="editStatus" Text="未选中" FontSize="11" Foreground="#969696"/>
                    </Grid>
                    <!-- 原文(只读) -->
                    <StackPanel Grid.Row="1" Margin="8,6">
                        <TextBlock Text="原文" FontSize="11" Foreground="#969696" Margin="0,0,0,2"/>
                        <TextBox Name="originalBox" IsReadOnly="True" FontSize="13" Height="100"
                                 AcceptsReturn="True" TextWrapping="Wrap" Background="#252526" BorderBrush="#3F3F46"/>
                    </StackPanel>
                    <!-- 译文(可编辑) -->
                    <StackPanel Grid.Row="2" Margin="8,4,8,8">
                        <TextBlock Text="译文" FontSize="11" Foreground="#4EC9B0" Margin="0,0,0,2"/>
                        <TextBox Name="translatedBox" FontSize="13"
                                 AcceptsReturn="True" TextWrapping="Wrap" Background="#252526" BorderBrush="#3F3F46"/>
                    </StackPanel>
                    <!-- 编辑操作按钮 -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6" Margin="8">
                        <Button Name="btnPrevEntry"    Content="上一条" Height="36" MinWidth="76" FontSize="12"/>
                        <Button Name="btnNextEntry"    Content="下一条" Height="36" MinWidth="76" FontSize="12"/>
                        <Button Name="btnCopyToTrans"  Content="原文→译文" Height="36" MinWidth="100" FontSize="12"/>
                        <Button Name="btnApplyEntry"   Content="应用" Height="36" MinWidth="68" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== 状态栏 ===== -->
        <Border Grid.Row="3" Background="#007ACC" Padding="10,4">
            <TextBlock Name="statusText" Text="就绪" Foreground="White" FontSize="12"/>
        </Border>

        <!-- ===== 日志 ===== -->
        <Border Grid.Row="4" Background="#1A1A1A" Padding="8,4" Height="80">
            <TextBox Name="logBox" IsReadOnly="True" FontSize="10" Foreground="#969696"
                     Background="Transparent" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True"/>
        </Border>

        <!-- ===== 文件选择器 overlay ===== -->
        <Border Name="fileBrowserOverlay" IsVisible="False"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <android:FileBrowserView Name="fileBrowser"/>
        </Border>

        <!-- ===== 进度 overlay ===== -->
        <Border Name="progressOverlay" IsVisible="False"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#1E1E1E" CornerRadius="8" Padding="20" MinWidth="280">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Name="progressText" Text="处理中..." FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                    <ProgressBar Name="progressBar" IsIndeterminate="True" Margin="0,12,0,0" MinWidth="240"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
