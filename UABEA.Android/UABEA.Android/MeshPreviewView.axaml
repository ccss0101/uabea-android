<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UABEA.Android.MeshPreviewView">
    <Border Background="#80000000"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <!-- 横屏宽幅布局:横向占满,适合横屏 3D 预览 -->
        <Border Background="#1E1E1E" CornerRadius="8" Padding="12"
                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                Margin="16,8" MaxWidth="900">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
                <!-- 标题 + 信息 -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="3D 预览" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="1" Name="meshInfo" FontSize="11" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                </Grid>
                <!-- 提示 + 错误 -->
                <TextBlock Grid.Row="1" Name="hintText" Text="拖动旋转 · 顶部 +/- 缩放" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" Name="errorText" FontSize="12" Foreground="#ff6666" Margin="0,0,0,4" IsVisible="False" TextWrapping="Wrap"/>
                <!-- 预览区 -->
                <Border Grid.Row="2" Background="#000000" BorderBrush="#333" BorderThickness="1" MinHeight="320" MaxHeight="480">
                    <Image Name="previewImage" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <!-- 底部按钮 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6" Margin="0,10,0,0">
                    <Button Name="btnZoomIn" Content="+" Height="40" MinWidth="56" FontSize="16"/>
                    <Button Name="btnZoomOut" Content="-" Height="40" MinWidth="56" FontSize="16"/>
                    <Button Name="btnWireframe" Content="线框/填充" Height="40" MinWidth="90" FontSize="12"/>
                    <Button Name="btnResetView" Content="重置视角" Height="40" MinWidth="80" FontSize="12"/>
                    <Button Name="btnClose" Content="关闭" Height="40" MinWidth="80" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
