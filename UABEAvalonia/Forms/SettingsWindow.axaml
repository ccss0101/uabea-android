<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:v="clr-namespace:UABEAvalonia.Views"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="640"
        x:Class="UABEAvalonia.Forms.SettingsWindow"
        Title="UABEA - Settings"
        Width="560" Height="640"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ShowInTaskbar="False">
    <!--
      Settings 窗口：单纯承载 SettingsView。
      SettingsView 自身的 Close 命令会关闭所在窗口。
    -->
    <Panel>
        <v:SettingsView />
    </Panel>
</Window>
